PORT=3001
NODE_ENV=development

REDIS_URL=redis://localhost:6379
# Set true on Windows / when redis-server is not installed (in-process mock + memory blacklist).
REDIS_MEMORY=true

JWT_ALGORITHM=RS256
JWT_ALLOWED_ALGORITHMS=RS256,ES256
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_ALLOWED_ISSUERS=jwt-shield-demo
JWT_ALLOWED_AUDIENCES=jwt-shield-api
JWT_MAX_TOKEN_AGE_SECONDS=86400
JWT_KEY_IDS=v1,v2
JWT_ACTIVE_KEY_ID=v2

IP_WARN_THRESHOLD=5
IP_BLOCK_THRESHOLD=10
IP_ATTACK_PERMANENT_THRESHOLD=3
IP_BLOCK_DURATION_SECONDS=3600

ENABLE_FINGERPRINT_BINDING=true

DASHBOARD_ORIGIN=http://localhost:5173

DEMO_USERNAME=demo
DEMO_PASSWORD=demo
